local ESP_Cache = {}

local function NewDrawing(Type, Props)
    local obj = Drawing.new(Type)
    for k, v in pairs(Props) do obj[k] = v end
    return obj
end

local function CreateESP(Player)
    local O = {
        Box              = NewDrawing("Square", {Thickness=1,   ZIndex=2, Visible=false}),
        BoxOutline       = NewDrawing("Square", {Thickness=3,   Color=Color3.new(0,0,0), ZIndex=1, Visible=false}),
        BoxFill          = NewDrawing("Square", {Filled=true,   ZIndex=0, Visible=false}),
        Name             = NewDrawing("Text",   {Text=Player.Name, Center=true, Size=ESP.TextSize, Font=ESP.Font, Outline=true, ZIndex=3, Visible=false}),
        Distance         = NewDrawing("Text",   {Center=true,   Size=ESP.TextSize-1, Font=ESP.Font, Outline=true, ZIndex=3, Visible=false}),
        HealthBar        = NewDrawing("Square", {Filled=true,   ZIndex=2, Visible=false}),
        HealthBarOutline = NewDrawing("Square", {Filled=true,   Color=Color3.new(0,0,0), ZIndex=1, Visible=false}),
        Tracer           = NewDrawing("Line",   {Thickness=1,   ZIndex=2, Visible=false}),
        TracerOutline    = NewDrawing("Line",   {Thickness=3,   Color=Color3.new(0,0,0), ZIndex=1, Visible=false}),
        SkeletonLines    = {},
        Highlight        = nil
    }
    for _ = 1, 20 do
        table.insert(O.SkeletonLines, NewDrawing("Line", {Thickness=1, ZIndex=2, Visible=false}))
    end
    ESP_Cache[Player] = O
end

local function RemoveESP(Player)
    local O = ESP_Cache[Player]
    if not O then return end
    for k, v in pairs(O) do
        if k == "Highlight" and v then
            pcall(function() v:Destroy() end)
        elseif k == "SkeletonLines" then
            for _, l in pairs(v) do pcall(function() l:Remove() end) end
        elseif v and v.Remove then
            pcall(function() v:Remove() end)
        end
    end
    ESP_Cache[Player] = nil
end

local SkeletonBones = {
    {"Head","UpperTorso"},
    {"UpperTorso","LowerTorso"},
    {"UpperTorso","LeftUpperArm"},   {"LeftUpperArm","LeftLowerArm"},    {"LeftLowerArm","LeftHand"},
    {"UpperTorso","RightUpperArm"},  {"RightUpperArm","RightLowerArm"},  {"RightLowerArm","RightHand"},
    {"LowerTorso","LeftUpperLeg"},   {"LeftUpperLeg","LeftLowerLeg"},    {"LeftLowerLeg","LeftFoot"},
    {"LowerTorso","RightUpperLeg"},  {"RightUpperLeg","RightLowerLeg"},  {"RightLowerLeg","RightFoot"},
    {"Head","Torso"},
    {"Torso","Left Arm"},  {"Torso","Right Arm"},
    {"Torso","Left Leg"},  {"Torso","Right Leg"}
}

RunService.RenderStepped:Connect(function()
    local lChar = LocalPlayer.Character
    local lRoot = lChar and lChar:FindFirstChild("HumanoidRootPart")

    for Player, O in pairs(ESP_Cache) do
        local char = Player.Character
        local hum  = char and char:FindFirstChildOfClass("Humanoid")
        local root = char and char:FindFirstChild("HumanoidRootPart")

        local valid    = ESP.Enabled and char and hum and root and hum.Health > 0
        local teammate = ESP.TeamCheck and Player.Team == LocalPlayer.Team

        local function hideAll()
            for k, v in pairs(O) do
                if k == "SkeletonLines" then
                    for _, l in pairs(v) do l.Visible = false end
                elseif k ~= "Highlight" and v and typeof(v) ~= "Instance" then
                    v.Visible = false
                end
            end
        end

        if valid and not teammate then
            -- Chams
            if ESP.Chams.Enabled then
                if not O.Highlight or not O.Highlight.Parent then
                    pcall(function() if O.Highlight then O.Highlight:Destroy() end end)
                    local hl = Instance.new("Highlight")
                    hl.Parent    = char
                    hl.Adornee   = char
                    hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
                    O.Highlight  = hl
                end
                local hl = O.Highlight
                hl.FillColor           = ESP.Chams.FillColor
                hl.OutlineColor        = ESP.Chams.OutlineColor
                hl.FillTransparency    = ESP.Chams.FillTransparency
                hl.OutlineTransparency = ESP.Chams.OutlineTransparency
                hl.Enabled = true
            else
                if O.Highlight then
                    pcall(function() O.Highlight:Destroy() end)
                    O.Highlight = nil
                end
            end

            local hrp3, onScreen = Camera:WorldToViewportPoint(root.Position)
            local dist = lRoot and (lRoot.Position - root.Position).Magnitude or 0

            if onScreen and dist <= ESP.LimitDistance then
                local sf   = 1 / (hrp3.Z * math.tan(math.rad(Camera.FieldOfView * 0.5)) * 2) * 1000
                local W    = math.floor(4 * sf)
                local H    = math.floor(6 * sf)
                local bPos = Vector2.new(math.floor(hrp3.X - W * 0.5), math.floor(hrp3.Y - H * 0.5))
                local c2d  = Vector2.new(hrp3.X, hrp3.Y)

                if ESP.Box.Enabled then
                    O.Box.Size=Vector2.new(W,H); O.Box.Position=bPos
                    O.Box.Color=ESP.Box.Color;   O.Box.Visible=true
                    O.BoxOutline.Size=Vector2.new(W,H); O.BoxOutline.Position=bPos
                    O.BoxOutline.Visible=ESP.Box.Outline
                else O.Box.Visible=false; O.BoxOutline.Visible=false end

                if ESP.BoxFill.Enabled and ESP.Box.Enabled then
                    O.BoxFill.Size=Vector2.new(W,H); O.BoxFill.Position=bPos
                    O.BoxFill.Color=ESP.BoxFill.Color
                    O.BoxFill.Transparency=ESP.BoxFill.Transparency
                    O.BoxFill.Visible=true
                else O.BoxFill.Visible=false end

                if ESP.Name.Enabled then
                    O.Name.Position=Vector2.new(bPos.X+W/2, bPos.Y-O.Name.TextBounds.Y-2)
                    O.Name.Color=ESP.Name.Color; O.Name.Visible=true
                else O.Name.Visible=false end

                if ESP.Distance.Enabled then
                    O.Distance.Text=math.floor(dist).."m"
                    O.Distance.Position=Vector2.new(bPos.X+W/2, bPos.Y+H+2)
                    O.Distance.Color=ESP.Distance.Color; O.Distance.Visible=true
                else O.Distance.Visible=false end

                if ESP.HealthBar.Enabled then
                    local bw = 2
                    local hy = H * (hum.Health / hum.MaxHealth)
                    O.HealthBarOutline.Size=Vector2.new(bw+2,H+2)
                    O.HealthBarOutline.Position=Vector2.new(bPos.X-bw-6, bPos.Y-1)
                    O.HealthBarOutline.Visible=true
                    O.HealthBar.Size=Vector2.new(bw, hy)
                    O.HealthBar.Position=Vector2.new(bPos.X-bw-5, bPos.Y+(H-hy))
                    O.HealthBar.Color=Color3.fromHSV((hum.Health/hum.MaxHealth)*0.3, 1, 1)
                    O.HealthBar.Visible=true
                else O.HealthBar.Visible=false; O.HealthBarOutline.Visible=false end

                if ESP.Tracer.Enabled then
                    local origin = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y)
                    if ESP.Tracer.Origin == "Center" then
                        origin = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
                    elseif ESP.Tracer.Origin == "Mouse" then
                        local m = UserInputService:GetMouseLocation()
                        origin  = Vector2.new(m.X, m.Y)
                    end
                    O.Tracer.From=origin; O.Tracer.To=c2d
                    O.Tracer.Color=ESP.Tracer.Color; O.Tracer.Visible=true
                    O.TracerOutline.From=origin; O.TracerOutline.To=c2d
                    O.TracerOutline.Visible=true
                else O.Tracer.Visible=false; O.TracerOutline.Visible=false end

                if ESP.Skeleton.Enabled then
                    local idx = 1
                    for _, pair in ipairs(SkeletonBones) do
                        local p1 = char:FindFirstChild(pair[1])
                        local p2 = char:FindFirstChild(pair[2])
                        if p1 and p2 then
                            local sp1, os1 = Camera:WorldToViewportPoint(p1.Position)
                            local sp2, os2 = Camera:WorldToViewportPoint(p2.Position)
                            if os1 or os2 then
                                local line = O.SkeletonLines[idx]
                                if line then
                                    line.From=Vector2.new(sp1.X,sp1.Y)
                                    line.To=Vector2.new(sp2.X,sp2.Y)
                                    line.Color=ESP.Skeleton.Color
                                    line.Thickness=ESP.Skeleton.Thickness
                                    line.Visible=true
                                    idx = idx + 1
                                end
                            end
                        end
                    end
                    for i = idx, #O.SkeletonLines do O.SkeletonLines[i].Visible=false end
                else
                    for _, l in pairs(O.SkeletonLines) do l.Visible=false end
                end
            else
                hideAll()
            end
        else
            hideAll()
            if O.Highlight then
                pcall(function() O.Highlight:Destroy() end)
                O.Highlight = nil
            end
        end
    end
end)

