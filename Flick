local function UpdateFOV()
    FOV_Frame.Size    = UDim2.new(0, Aimbot.FOV*2, 0, Aimbot.FOV*2)
    FOV_Frame.Visible = Aimbot.FOV_Enabled and Aimbot.Enabled
    FOV_Stroke.Color  = Aimbot.FOV_Color
end

-- ┌─────────────────────────────────────────────────────────┐
-- │                   CORE AIMBOT                           │
-- └─────────────────────────────────────────────────────────┘
local function GetTarget()
    local best, bestDist = nil, Aimbot.FOV
    local vCX = Camera.ViewportSize.X / 2
    local vCY = Camera.ViewportSize.Y / 2

    for _, plr in ipairs(Players:GetPlayers()) do
        if plr == LocalPlayer then continue end
        local char = plr.Character
        if not char then continue end
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then continue end
        if Aimbot.TeamCheck and plr.Team == LocalPlayer.Team then continue end

        local part = char:FindFirstChild(Aimbot.AimPart) or char:FindFirstChild("HumanoidRootPart")
        if not part then continue end

        local pos = part.Position
        if Aimbot.Prediction then
            local vel = part:IsA("BasePart") and part.AssemblyLinearVelocity or Vector3.zero
            pos = pos + vel * Aimbot.PredictionAmount
        end

        local sp, onScreen = Camera:WorldToViewportPoint(pos)
        if not onScreen then continue end

        local d = (Vector2.new(sp.X, sp.Y) - Vector2.new(vCX, vCY)).Magnitude
        if d >= bestDist then continue end

        if Aimbot.VisibleCheck then
            local rp = RaycastParams.new()
            rp.FilterDescendantsInstances = {LocalPlayer.Character}
            rp.FilterType = Enum.RaycastFilterType.Exclude
            local res = Workspace:Raycast(Camera.CFrame.Position, pos - Camera.CFrame.Position, rp)
            if res and not res.Instance:IsDescendantOf(char) then continue end
        end

        bestDist = d
        best     = pos
    end
    return best
end

RunService.Heartbeat:Connect(function()
    UpdateFOV()

    local shouldAim = Aimbot.Enabled and
        (Aimbot.ToggleMode or UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2))

    if not shouldAim then
        FOV_Stroke.Color = Aimbot.FOV_Color
        return
    end

    local target = GetTarget()
    if target then
        FOV_Stroke.Color = Aimbot.FOV_LockedColor
        local look = CFrame.lookAt(Camera.CFrame.Position, target)
        Camera.CFrame = Camera.CFrame:Lerp(look, 1 / math.max(1, Aimbot.Smoothness))
    else
        FOV_Stroke.Color = Aimbot.FOV_Color
    end
end)

